---
import {
	GITHUB_PROJECTS_REQUIRED_TOPIC,
	GITHUB_USERNAME,
} from '../consts';
import { getGitHubProjects } from '../lib/github-projects';
import FormattedDate from './FormattedDate.astro';

const githubProjects = await getGitHubProjects();
const githubProfileUrl = `https://github.com/${GITHUB_USERNAME}`;
---

{
	githubProjects.enabled && (
		<div class="mt-20">
			<div class="text-center mb-12">
				<h3 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white mb-4">
					Public Repos on GitHub
				</h3>
				<p class="mt-4">
					<a
						href={githubProfileUrl}
						target="_blank"
						rel="noopener"
						class="text-purple-600 dark:text-purple-400 hover:underline"
					>
						View all repositories on GitHub
					</a>
				</p>
			</div>

			{
				githubProjects.errorMessage ? (
					<div class="max-w-3xl mx-auto rounded-xl border border-amber-300 bg-amber-50/90 dark:border-amber-700 dark:bg-amber-950/40 p-6 text-center text-amber-900 dark:text-amber-100">
						<p>{githubProjects.errorMessage}</p>
						<p class="mt-3 text-sm opacity-80">
							Trigger a new build after GitHub connectivity is restored to refresh this section.
						</p>
					</div>
				) : githubProjects.projects.length === 0 ? (
					<div class="max-w-3xl mx-auto rounded-xl border border-gray-200 bg-white/80 dark:border-gray-700 dark:bg-gray-900/60 p-6 text-center text-gray-600 dark:text-gray-300">
						<p>No public repositories are currently tagged with <code class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-sm">{GITHUB_PROJECTS_REQUIRED_TOPIC}</code>.</p>
					</div>
				) : (
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
						{
							githubProjects.projects.map((project) => (
								<article class="project-card bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 p-6 flex flex-col">
									<div class="flex items-start justify-between gap-4 mb-4">
										<h4 class="text-xl font-semibold text-gray-800 dark:text-white break-words">
											{project.name}
										</h4>
										{
											project.stars > 0 && (
												<span class="shrink-0 rounded-full bg-yellow-100 dark:bg-yellow-900 px-3 py-1 text-xs font-semibold text-yellow-800 dark:text-yellow-200">
													{project.stars} star{project.stars === 1 ? '' : 's'}
												</span>
											)
										}
									</div>

									<p class="text-gray-600 dark:text-gray-300 mb-4 flex-1">
										{project.description}
									</p>

									<div class="flex flex-wrap gap-2 mb-4">
										{
											project.language && (
												<span class="px-2 py-1 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded text-sm">
													{project.language}
												</span>
											)
										}
										{
											project.topics.map((topic) => (
												<span class="px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200 rounded text-sm">
													{topic}
												</span>
											))
										}
									</div>

									<p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
										Last push <FormattedDate date={project.pushedAt} />
									</p>

									<div class="flex flex-wrap gap-4">
										<a
											href={project.repoUrl}
											target="_blank"
											rel="noopener"
											class="text-purple-600 dark:text-purple-400 hover:underline"
										>
											View Repo
										</a>
										{
											project.homepageUrl && (
												<a
													href={project.homepageUrl}
													target="_blank"
													rel="noopener"
													class="text-purple-600 dark:text-purple-400 hover:underline"
												>
													Live Site
												</a>
											)
										}
									</div>
								</article>
							))
						}
					</div>
				)
			}
		</div>
	)
}
